{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WhatsNew",
  "version": "0.1.0",
  "identifier": "dev.ckabelin.whatsnew",
  "build": {
    "beforeDevCommand": "npm --prefix web run dev",
    "beforeBuildCommand": "npm --prefix web run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web/build"
  },
  "app": {
    "windows": [
      {
        "title": "WhatsNew",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
